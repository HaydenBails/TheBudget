# Node
node_modules/
dist/
dist-ssr/
*.local
.vite/

# EXCEPTION: the built web UI is committed so the app runs with Python only
# (no Node needed to run it). Rebuild with `npm run build` in apps/web when the
# frontend changes.
!/apps/web/dist/
!/apps/web/dist/**

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# SQLite (local data)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Env / secrets
.env
.env.*
!.env.example

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Test / build artifacts
coverage/
playwright-report/
test-results/
*.log

# Backend test-run scratch roots (never source or fixtures)
/apps/api/.test-tmp*/
/apps/api/.fe*-test/
/apps/api/output/
/apps/api/be[0-9][0-9]-*/
/apps/api/qa[0-9][0-9]-*/
/apps/api/pytest-cache-files-*/

# Temporary statement uploads (never persisted)
tmp-uploads/

# Test/QA artifacts (screenshots, scratch scripts) — never committed.
output/
