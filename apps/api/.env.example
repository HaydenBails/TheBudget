# Copy to .env and adjust as needed. All keys use the ST_ prefix.
# Local-first: keep the host on loopback unless you know what you are doing.
ST_HOST=127.0.0.1
ST_PORT=8787
ST_DATABASE_PATH=data/spending_tracker.db
# Optional statement-import safety overrides (defaults shown).
ST_IMPORT_MAX_BYTES=15728640
ST_IMPORT_MULTIPART_OVERHEAD_BYTES=65536
ST_IMPORT_MAX_PAGES=20
ST_IMPORT_MAX_EXTRACTED_CHARS=2000000
ST_IMPORT_EXTRACTION_TIMEOUT_SECONDS=15
# Optional server-owned temp/key locations; defaults use the system temp folder
# and a private key beside the configured database.
# ST_IMPORT_TEMP_ROOT=data/import-temp
# ST_IMPORT_FINGERPRINT_KEY_PATH=data/.import-fingerprint.key
